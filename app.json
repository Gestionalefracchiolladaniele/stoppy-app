{
  "expo": {
    "name": "Stoppy",
    "slug": "stoppy-app",
    "owner": "praticantisokagakkai",
    "version": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "f6803869-91b0-4a05-ad3c-a42939c6852a"
      }
    },
    "scheme": "stoppy",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0F2218"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.stoppy.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F2218"
      }
    },
    "ios": {
      "bundleIdentifier": "com.stoppy.app",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.PLACEHOLDER"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/f6803869-91b0-4a05-ad3c-a42939c6852a"
    }
  }
}
