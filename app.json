{
  "expo": {
    "name": "Noit",
    "slug": "noit",
    "owner": "praticantisokagakkai",
    "version": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "c3a711e8-1d8a-496d-9db3-4a2139c6c322"
      }
    },
    "scheme": "noit",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#140d2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.noit.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5C3E9C"
      }
    },
    "ios": {
      "bundleIdentifier": "com.noit.app",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.PLACEHOLDER"
        }
      ]
    ]
  }
}
